                "bookmarks:write",
                "calls:read",
                "calls:write",
                "canvases:read",
                "canvases:write",
                "channels:history",
                "channels:read",
                "channels:write",
                "chat:write",
                "dnd:read",
                "dnd:write",
                "emoji:read",
                "files:read",
                "files:write",
                "groups:read",
                "groups:write",
                "im:history",
                "im:read",
                "im:write",
                "links.embed:write",
                "links:read",
                "links:write",
                "mpim:history",
                "mpim:read",
                "mpim:write",
                "mpim:write.topic",
                "pins:read",
                "pins:write",
                "reactions:read",
                "reactions:write",
                "reminders:read",
                "reminders:write",
                "remote_files:read",
                "remote_files:share",
                "search:read",
                "team:read",
                "usergroups:read",
                "usergroups:write",
                "users.profile:read",
                "users.profile:write",
                "users:read",
                "users:read.email",
                "users:write"
