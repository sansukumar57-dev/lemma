            "bot": [
                "app_mentions:read",
                "assistant:write",
                "bookmarks:read",
                "calls:read",
                "channels:history",
                "channels:manage",
                "channels:read",
                "chat:write",
                "chat:write.customize",
                "chat:write.public",
                "files:read",
                "files:write",
                "groups:write",
                "im:history",
                "im:read",
                "im:write",
                "im:write.topic",
                "mpim:history",
                "mpim:read",
                "mpim:write",
                "bookmarks:write",
                "reactions:read",
                "reactions:write",
                "users:read",
                "users:read.email",
                "users.profile:read"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "request_url": "https://api.lemma.work/surfaces/webhooks/slack",
            "user_events": [
                "message.channels"
            ],
            "bot_events": [
                "app_mention",
                "assistant_thread_started",
                "message.channels",
                "message.im"
            ]
        },
        "interactivity": {
            "is_enabled": true,
            "request_url": "https://api.lemma.work/surfaces/webhooks/slack"
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": false,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}