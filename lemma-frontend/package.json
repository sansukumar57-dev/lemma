{
  "name": "lemma-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:lemma-sdk": "npm --prefix ../lemma-typescript run build",
    "predev": "npm run prepare:lemma-sdk && node scripts/gen-runtime-config.mjs",
    "dev": "next dev",
    "gen:runtime-config": "node scripts/gen-runtime-config.mjs",
    "prebuild": "npm run prepare:lemma-sdk",
    "build": "next build",
    "prelint": "npm run prepare:lemma-sdk",
    "start": "next start",
    "lint": "eslint",
    "pretest": "npm run prepare:lemma-sdk",
    "test": "vitest run",
    "pretypecheck": "npm run prepare:lemma-sdk",
    "typecheck": "tsc --noEmit --pretty false --skipLibCheck",
    "check:edu-anchors": "node scripts/check-edu-anchors.mjs",
    "check": "npm run design:audit:ci && npm run lint && npm run typecheck && npm run check:edu-anchors",
    "design:audit": "node scripts/audit-design-system.mjs",
    "design:audit:assistant-ratchet": "node scripts/audit-design-system.mjs --baseline scripts/design-audit-baseline.json --max-informational=",
    "design:audit:baseline": "node scripts/audit-design-system.mjs --print-baseline",
    "design:audit:changed": "node scripts/audit-design-system.mjs --details --changed",
    "design:audit:changed-queue": "node scripts/audit-design-system.mjs --queue --changed",
    "design:audit:ci": "npm run design:audit:test && node scripts/audit-design-system.mjs --strict --baseline scripts/design-audit-baseline.json --quiet",
    "design:audit:details": "node scripts/audit-design-system.mjs --details",
    "design:audit:focus": "node scripts/audit-design-system.mjs --details --paths",
    "design:audit:json": "node scripts/audit-design-system.mjs --json",
    "design:audit:queue": "node scripts/audit-design-system.mjs --queue",
    "design:audit:ratchet": "node scripts/audit-design-system.mjs --baseline scripts/design-audit-baseline.json --max-protected-assistant=",
    "design:audit:summary": "node scripts/audit-design-system.mjs --json --summary",
    "design:audit:strict": "node scripts/audit-design-system.mjs --strict",
    "design:audit:test": "node scripts/test-design-audit.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.12",
    "@tiptap/core": "3.20.4",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/extension-table": "3.20.4",
    "@tiptap/extension-table-cell": "3.20.4",
    "@tiptap/extension-table-header": "3.20.4",
    "@tiptap/extension-table-row": "3.20.4",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lemma-sdk": "file:../lemma-typescript",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.11.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "node-html-parser": "^7.0.2",
    "pdfjs-dist": "^5.5.207",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "supertokens-auth-react": "^0.51.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "@xmldom/xmldom": "0.9.10",
    "dompurify": "3.4.11",
    "js-yaml": "4.2.0",
    "lodash": "4.18.1",
    "markdown-it": "14.2.0",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.15"
    },
    "minimatch@10.2.4": {
      "brace-expansion": "5.0.6"
    },
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.6"
    },
    "postcss": "8.5.15"
  }
}
