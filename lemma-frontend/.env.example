# Lemma Frontend environment configuration.
#
# Copy this file to .env.local and edit the values you need:
#
#   cp .env.example .env.local
#
# Every value has a sensible local default, so an empty .env.local will run
# against a local backend at https://api.localhost. Uncomment and set only the
# variables you want to override.
#
# These are NEXT_PUBLIC_* variables, applied at runtime. After editing while the
# dev server is running, run `npm run gen:runtime-config` and hard-refresh.

# --- Backend / URLs ------------------------------------------------------
# Base URL of the Lemma backend API.
# NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Public URL this frontend is served from.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL that handles auth flows (usually the same as the site URL).
# NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# --- Sessions / cookies --------------------------------------------------
# Cookie domain for the session. Set to your apex domain (e.g. .example.com)
# ONLY when the site is served from that domain. Leave EMPTY on localhost —
# a domain-scoped cookie will not be sent from localhost and auth will fail.
# NEXT_PUBLIC_SESSION_TOKEN_DOMAIN=

# Apex domain used to share one login across sibling subdomains (e.g. desk
# apps). Leave unset for single-host cookies.
# NEXT_PUBLIC_SHARED_SESSION_DOMAIN=.example.com

# Domain suffix under which pod desk apps are served. Optional.
# NEXT_PUBLIC_APPS_DOMAIN_SUFFIX=apps.example.com

# --- Branding / contact --------------------------------------------------
# Contact address shown on legal pages and support links.
# NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Display name used by the auth portal.
# NEXT_PUBLIC_APP_NAME=Lemma Auth
