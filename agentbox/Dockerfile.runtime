# Build context must be the monorepo root:
#   docker build -f agentbox/Dockerfile.runtime .
ARG PYTHON_IMAGE=python:3.14.4-slim
ARG NODE_IMAGE=node:25.9.0-slim

FROM ${NODE_IMAGE} AS node-runtime
FROM ${PYTHON_IMAGE}

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_COMPILE_BYTECODE=1 \
    PYTHONPATH=/app \
    NPM_CONFIG_AUDIT=false \
    NPM_CONFIG_FUND=false \
    NPM_CONFIG_UPDATE_NOTIFIER=false \
    DISPLAY=:99 \
    HOME=/home/appuser \
    XDG_RUNTIME_DIR=/tmp/workspace-runtime \
    WORKSPACE_XVFB_SCREEN=1440x960x24 \
    AGENT_BROWSER_CONFIG=/workspace/agent-browser.json \
    AGENT_BROWSER_DASHBOARD_PORT=4848 \
    AGENT_BROWSER_DASHBOARD_INTERNAL_PORT=4849 \
    AGENT_BROWSER_EXECUTABLE_PATH=/usr/local/bin/workspace-chrome \
    AGENT_BROWSER_PROFILE=/workspace/.browser-profile \
    AGENT_BROWSER_SESSION_NAME=workspace \
    AGENT_BROWSER_SESSION=workspace \
    AGENT_BROWSER_HEADED=true \
    AGENTBOX_FUNCTION_EXECUTOR_PORT=8090 \
    NODE_PATH=/usr/local/lib/node_modules \
    MPLBACKEND=Agg

RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    chromium \
    curl \
    fonts-dejavu-core \
    fonts-liberation \
    git \
    libasound2t64 \
    libatk-bridge2.0-0t64 \
    libatk1.0-0t64 \
    libatomic1 \
    libatspi2.0-0t64 \
    libcairo2 \
    libcups2t64 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libxcomposite1 \
    libxdamage1 \
    libxkbcommon0 \
    procps \
    ripgrep \
    socat \
    tini \
    xvfb \
    && rm -rf /var/lib/apt/lists/*

COPY --from=node-runtime /usr/local/bin/node /usr/local/bin/node
COPY --from=node-runtime /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -sf /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -sf /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx \
    && node --version \
    && npm --version \
    && npx --version

RUN groupadd --gid 10001 appuser \
    && useradd --uid 10001 --gid 10001 -d /home/appuser -m appuser \
    && mkdir -p /workspace /workspace/.browser-profile /home/appuser/.cache /tmp/.X11-unix /tmp/workspace-runtime \
    && chmod 1777 /tmp/.X11-unix \
    && chown -R appuser:appuser /workspace /home/appuser /tmp/workspace-runtime

RUN pip install --no-cache-dir --disable-pip-version-check uv
RUN uv pip install --system --no-cache-dir \
    "fastapi[standard]>=0.128.0" \
    "pydantic>=2.11.0" \
    "uvicorn[standard]>=0.42.0"
# Pre-install the data/reporting packages agents reach for most often so the
# common case (charts, spreadsheets, dataframes) needs no on-demand install. The
# sandbox runs non-root, so runtime installs go to the user site via plain
# `pip install <pkg>` (pip auto-falls back to --user); these baked-in ones are on
# the system site, importable by the execute_python kernel out of the box.
RUN uv pip install --system --no-cache-dir \
    numpy \
    pandas \
    matplotlib \
    openpyxl \
    pillow \
    requests \
    tabulate \
    python-dateutil

# Cache-bust: the build passes CACHE_BUST (git SHA / timestamp). Changing it forces
# this layer AND everything below it — the @latest npm tooling and the lemma
# SDK/CLI install — to re-run, so a rebuilt runtime image always ships the latest
# published npm tools and a fresh install of the current lemma source.
ARG CACHE_BUST=dev
RUN echo "cache-bust: ${CACHE_BUST}" \
    && npm install -g \
    @llamaindex/liteparse@latest \
    @mozilla/readability@latest \
    agent-browser@latest \
    create-vite@latest \
    eslint@latest \
    jsdom@latest \
    pnpm@latest \
    prettier@latest \
    react@latest \
    react-dom@latest \
    tsx@latest \
    turndown@latest \
    typescript@latest \
    vite@latest \
    && if command -v chromium >/dev/null 2>&1; then \
        ln -sf "$(command -v chromium)" /usr/local/bin/workspace-chrome; \
    elif command -v chromium-browser >/dev/null 2>&1; then \
        ln -sf "$(command -v chromium-browser)" /usr/local/bin/workspace-chrome; \
    else \
        echo "ERROR: system chromium is not installed" >&2; \
        exit 1; \
    fi

RUN printf '%s\n' \
    '{' \
    '  "headed": true,' \
    '  "profile": "/workspace/.browser-profile",' \
    '  "sessionName": "workspace",' \
    '  "executablePath": "/usr/local/bin/workspace-chrome",' \
    '  "args": "--no-sandbox,--disable-dev-shm-usage,--no-first-run,--no-default-browser-check"' \
    '}' \
    > /workspace/agent-browser.json \
    && chown appuser:appuser /workspace/agent-browser.json

COPY lemma-python /sdk/lemma-python
COPY lemma-cli /sdk/lemma-cli
COPY lemma-typescript /sdk/lemma-typescript
# lemma-skills is gitignored inside lemma-cli (vendored at build time), so copy
# it explicitly here so setup.py can vendor it while building the wheel.
COPY lemma-skills /sdk/lemma-skills
# Regular (non-editable) install: nothing edits the SDK/CLI inside a sandbox, so
# editable mode only adds a per-import finder hook and, worse, skips bytecode
# precompilation. lemma-cli pins lemma-sdk to the sibling path (non-editable),
# so this lands in site-packages where UV_COMPILE_BYTECODE=1 precompiles every
# module and `lemma` never recompiles from source on startup.
#
# Keep the source tree at /sdk after install (read-only reference): functions and
# agents read it to learn SDK response shapes, method signatures, and facades —
# e.g. `cat /sdk/lemma-python/lemma_sdk/resources/data.py`. The TypeScript SDK
# source ships too for desk authors. node_modules/.venv/dist are excluded by
# .dockerignore, so this adds source only (~25MB).
RUN uv pip install --system /sdk/lemma-python /sdk/lemma-cli \
    && chmod -R a+rX /sdk

COPY agentbox/agentbox/__init__.py agentbox/agentbox/runtime_server.py agentbox/agentbox/function_executor.py ./agentbox/
RUN python -m compileall -q ./agentbox

COPY agentbox/scripts/start-browser.sh /usr/local/bin/start-browser
COPY agentbox/scripts/start-runtime.sh /usr/local/bin/start-runtime
COPY agentbox/scripts/save-webpage.sh /usr/local/bin/save-webpage
COPY agentbox/scripts/webpage-to-markdown.mjs /usr/local/lib/webpage-to-markdown.mjs
RUN chmod +x /usr/local/bin/start-browser /usr/local/bin/start-runtime /usr/local/bin/save-webpage /usr/local/lib/webpage-to-markdown.mjs

WORKDIR /workspace
USER 10001:10001

EXPOSE 8080 8090

CMD ["tini", "--", "start-runtime"]
