{
  "components": {
    "schemas": {
      "FunctionExecuteRequest": {
        "properties": {
          "async_job": {
            "default": false,
            "title": "Async Job",
            "type": "boolean"
          },
          "input_data": {
            "additionalProperties": true,
            "title": "Input Data",
            "type": "object"
          },
          "run_id": {
            "format": "uuid",
            "title": "Run Id",
            "type": "string"
          },
          "timeout_seconds": {
            "default": 120,
            "maximum": 3600.0,
            "minimum": 1.0,
            "title": "Timeout Seconds",
            "type": "integer"
          }
        },
        "required": [
          "run_id"
        ],
        "title": "FunctionExecuteRequest",
        "type": "object"
      },
      "FunctionJobStatusResponse": {
        "properties": {
          "code_hash": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Code Hash"
          },
          "completed_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          },
          "duration_ms": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Ms"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RuntimeErrorInfo"
              },
              {
                "type": "null"
              }
            ]
          },
          "job_id": {
            "title": "Job Id",
            "type": "string"
          },
          "output_data": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Output Data"
          },
          "run_id": {
            "format": "uuid",
            "title": "Run Id",
            "type": "string"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "status": {
            "enum": [
              "queued",
              "running",
              "completed",
              "failed",
              "cancelled",
              "timeout"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "run_id",
          "job_id",
          "status"
        ],
        "title": "FunctionJobStatusResponse",
        "type": "object"
      },
      "FunctionLogEntry": {
        "properties": {
          "message": {
            "title": "Message",
            "type": "string"
          },
          "stream": {
            "enum": [
              "stdout",
              "stderr",
              "system"
            ],
            "title": "Stream",
            "type": "string"
          },
          "timestamp": {
            "title": "Timestamp",
            "type": "string"
          }
        },
        "required": [
          "timestamp",
          "stream",
          "message"
        ],
        "title": "FunctionLogEntry",
        "type": "object"
      },
      "FunctionLogsResponse": {
        "properties": {
          "logs": {
            "items": {
              "$ref": "#/components/schemas/FunctionLogEntry"
            },
            "title": "Logs",
            "type": "array"
          },
          "run_id": {
            "format": "uuid",
            "title": "Run Id",
            "type": "string"
          }
        },
        "required": [
          "run_id"
        ],
        "title": "FunctionLogsResponse",
        "type": "object"
      },
      "FunctionSchemaRequest": {
        "properties": {
          "code_hash": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Code Hash"
          }
        },
        "title": "FunctionSchemaRequest",
        "type": "object"
      },
      "FunctionSchemaResponse": {
        "properties": {
          "code_hash": {
            "title": "Code Hash",
            "type": "string"
          },
          "config_schema": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Config Schema"
          },
          "input_schema": {
            "additionalProperties": true,
            "title": "Input Schema",
            "type": "object"
          },
          "output_schema": {
            "additionalProperties": true,
            "title": "Output Schema",
            "type": "object"
          }
        },
        "required": [
          "input_schema",
          "output_schema",
          "code_hash"
        ],
        "title": "FunctionSchemaResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "RuntimeErrorInfo": {
        "properties": {
          "message": {
            "title": "Message",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "retryable": {
            "default": false,
            "title": "Retryable",
            "type": "boolean"
          },
          "traceback": {
            "items": {
              "type": "string"
            },
            "title": "Traceback",
            "type": "array"
          }
        },
        "required": [
          "name",
          "message"
        ],
        "title": "RuntimeErrorInfo",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "AgentBox Function Executor",
