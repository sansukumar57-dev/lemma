{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lemma",
  "version": "0.2.1",
  "identifier": "work.lemma.desktop",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
